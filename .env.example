# --- LLM Providers ---

# Gemini Configuration (Recommended / First-class support)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# OpenAI / Groq / custom OpenAI-compatible endpoint
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=llama-3.3-70b-versatile

# Anthropic Configuration
ANTHROPIC_API_KEY=

# --- Mem0 Configuration (Long-term memory) ---
MEM0_API_KEY=
MEM0_BASE_URL=https://api.mem0.ai/v3
MEM0_USER_ID=groww-weekly-pulse

# --- Express API Server Port ---
PORT=3000

# --- Delivery & Notification Channels (Fallback / Default configs if not set in UI) ---
SLACK_WEBHOOK_URL=

# SMTP Email Configuration
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_TO=
EMAIL_FROM=groww-pulse@groww.in
