{
  "name": "weekly-review-pulse-agent",
  "version": "1.0.0",
  "description": "Autonomous AI agent that produces weekly review pulse reports for Groww with long-term memory via Mem0",
  "type": "module",
  "scripts": {
    "start": "node dist/agent/index.js",
    "server": "node dist/server/index.js",
    "server:dev": "tsx server/index.ts",
    "frontend:dev": "npm --prefix frontend run dev",
    "dev": "node scripts/dev.mjs",
    "dev:separate": "node scripts/dev.mjs",
    "build:backend": "tsc",
    "build:frontend": "npm --prefix frontend run build",
    "build:all": "npm run build:backend && npm run build:frontend",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "node scripts/clean.mjs"
  },
  "keywords": [
    "ai-agent",
    "mem0",
    "groww",
    "weekly-pulse",
    "app-store-reviews"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "commander": "^14.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "google-play-scraper": "^10.1.2",
    "nodemailer": "^8.0.7"
  },
  "devDependencies": {
    "@types/cors": "^2.8.6",
    "@types/express": "^5.0.0",
    "@types/node": "^25.9.1",
    "@types/nodemailer": "^8.0.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
